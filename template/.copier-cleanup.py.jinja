import os
import shutil
from pathlib import Path

def remove_path(path_str):
    path = Path(path_str)
    if path.exists():
        if path.is_dir():
            shutil.rmtree(path)
            print(f"Removed directory: {path_str}")
        else:
            os.remove(path)
            print(f"Removed file: {path_str}")

# =============================================================================
# Conditional Deletions
# =============================================================================

if not {{ include_github }}:
    remove_path(".github")
    remove_path("renovate.json")

if not {{ include_docs }}:
    remove_path("docs")
    remove_path("mkdocs.yml")
    remove_path(".github/workflows/docs.yml")

if not {{ include_tests }}:
    remove_path("tests")

if not {{ include_pre_commit }}:
    remove_path(".pre-commit-config.yaml")

if not {{ include_ci }} and {{ include_github }}:
    remove_path(".github/workflows/ci.yml")

if not {{ include_pypi_publish }} and {{ include_github }}:
    remove_path(".github/workflows/publish.yml")

if not {{ include_renovate }} and {{ include_github }}:
    remove_path("renovate.json")

# =============================================================================
# Self-Destruct
# =============================================================================

remove_path(".copier-cleanup.py")
