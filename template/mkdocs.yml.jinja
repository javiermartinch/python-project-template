# =============================================================================
# MkDocs Material — Documentation Site Configuration
# Build: uv run mkdocs build | Serve: uv run mkdocs serve
# =============================================================================

site_name: "{{ project_name }}"
site_url: "https://{{ github_org }}.github.io/{{ project_name }}"
site_description: "{{ project_description }}"
site_author: "{{ author_name }}"

{% if include_github -%}
repo_name: "{{ github_org }}/{{ project_name }}"
repo_url: "https://github.com/{{ github_org }}/{{ project_name }}"
edit_uri: "edit/main/docs/"
{%- endif %}

# ---------------------------------------------------------------------------
# Theme
# ---------------------------------------------------------------------------

theme:
  name: material

  palette:
    # Light mode
    - scheme: default
      primary: indigo
      accent: amber
      toggle:
        icon: material/brightness-7
        name: Switch to dark mode

    # Dark mode
    - scheme: slate
      primary: indigo
      accent: amber
      toggle:
        icon: material/brightness-4
        name: Switch to light mode

  font:
    text: Inter
    code: JetBrains Mono

  features:
    - navigation.instant          # SPA-like navigation (no full page reloads)
    - navigation.instant.progress # Loading progress bar
    - navigation.tracking         # URL updates to current anchor
    - navigation.tabs             # Top-level sections as tabs
    - navigation.sections         # Expandable sections in sidebar
    - navigation.top              # Back-to-top button
    - navigation.footer           # Previous/Next links in footer
    - search.suggest              # Search suggestions
    - search.highlight            # Highlight search terms on page
    - content.code.copy           # Copy button on code blocks
    - content.code.annotate       # Code annotations
    - content.tabs.link           # Linked content tabs
    - toc.follow                  # TOC follows scroll position

  {% if include_github -%}
  icon:
    repo: fontawesome/brands/github
  {%- endif %}

# ---------------------------------------------------------------------------
# Navigation
# ---------------------------------------------------------------------------

nav:
  - Home: index.md
  - Quick Start: quick-start.md
  - API Reference: api.md

# ---------------------------------------------------------------------------
# Plugins
# ---------------------------------------------------------------------------

plugins:
  - search
  - minify:
      minify_html: true
  - mkdocstrings:
      default_handler: python
      handlers:
        python:
          paths: ["src"]
          options:
            show_source: true
            show_root_heading: true
            show_symbol_type_heading: true
            show_symbol_type_toc: true
            docstring_style: google
            merge_init_into_class: true
            show_if_no_docstring: false

# ---------------------------------------------------------------------------
# Markdown Extensions
# ---------------------------------------------------------------------------

markdown_extensions:
  # Python Markdown (stdlib)
  - abbr
  - admonition
  - attr_list
  - def_list
  - footnotes
  - md_in_html
  - tables
  - toc:
      permalink: true
      toc_depth: 3

  # PyMdown Extensions (bundled with Material)
  - pymdownx.arithmatex:
      generic: true
  - pymdownx.betterem
  - pymdownx.caret
  - pymdownx.details
  - pymdownx.emoji:
      emoji_index: !!python/name:material.extensions.emoji.twemoji
      emoji_generator: !!python/name:material.extensions.emoji.to_svg
  - pymdownx.highlight:
      anchor_linenums: true
      line_spans: __span
      pygments_lang_class: true
  - pymdownx.inlinehilite
  - pymdownx.keys
  - pymdownx.mark
  - pymdownx.smartsymbols
  - pymdownx.superfences:
      custom_fences:
        - name: mermaid
          class: mermaid
          format: !!python/name:pymdownx.superfences.fence_code_format
  - pymdownx.tabbed:
      alternate_style: true
  - pymdownx.tasklist:
      custom_checkbox: true
  - pymdownx.tilde

# ---------------------------------------------------------------------------
# Extra
# ---------------------------------------------------------------------------

extra:
  social:
    {% if include_github -%}
    - icon: fontawesome/brands/github
      link: https://github.com/{{ github_org }}/{{ project_name }}
    {%- endif %}
    - icon: fontawesome/brands/python
      link: https://pypi.org/p/{{ project_name }}


