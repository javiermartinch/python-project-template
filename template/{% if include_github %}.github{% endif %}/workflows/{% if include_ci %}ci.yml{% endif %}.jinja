{% raw -%}
# =============================================================================
# Elite CI Pipeline — Fail-Fast DAG
# Order: Lint → Format → Typecheck → Test (matrix)
# =============================================================================

name: CI

on:
  push:
    branches: ["main"]
  pull_request:

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  # ── Gate 1: Static Analysis (O(1) — fast, single runner) ──────────────────
  static-analysis:
    name: Static Analysis
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Setup uv with cache
        uses: astral-sh/setup-uv@v7
        with:
          enable-cache: true

      - name: Install dependencies (locked)
        run: uv sync --locked --all-extras --dev

      - name: Ruff Linter
        run: uv run ruff check .

      - name: Ruff Formatter (check only)
        run: uv run ruff format --check .

      - name: Pyright Strict Type Checking
        run: uv run pyright
{% endraw %}
  # ── Gate 2: Test Matrix (depends on static analysis) ──────────────────────
  {% if include_tests -%}
  {% raw -%}
  test:
    name: Test — ${{ matrix.os }} / Python ${{ matrix.python-version }} (${{ matrix.resolution }})
    needs: static-analysis
    runs-on: ${{ matrix.os }}
    strategy:
      fail-fast: false
      matrix:
        os: ${{ (github.event_name == 'push' && github.ref == 'refs/heads/main') && fromJSON('["ubuntu-latest", "macos-latest", "windows-latest"]') || fromJSON('["ubuntu-latest"]') }}
        python-version: ["3.12", "3.13", "3.14"]
        resolution: [highest]
        include:
          # ── Lowest-direct: validate dependency lower bounds (ubuntu-only) ──
          - os: ubuntu-latest
            python-version: "3.12"
            resolution: lowest-direct
    env:
      UV_PYTHON: ${{ matrix.python-version }}
    steps:
      - uses: actions/checkout@v4

      - name: Setup uv with cache
        uses: astral-sh/setup-uv@v7
        with:
          enable-cache: true
          cache-suffix: ${{ matrix.resolution }}

      - name: Install dependencies (${{ matrix.resolution }})
        run: uv sync --locked --all-extras --dev --resolution=${{ matrix.resolution }}

      - name: Run tests with coverage
        run: uv run pytest --cov=src --cov-report=term-missing

      - name: Prune uv cache
        run: uv cache prune --ci
  {% endraw %}
  {% endif -%}

  # ── Gate 3: Documentation Build (depends on static analysis) ────────────
  {% if include_docs -%}
  {% raw -%}
  docs:
    name: Docs Build
    needs: static-analysis
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Setup uv
        uses: astral-sh/setup-uv@v7
        with:
          enable-cache: true

      - name: Install docs dependencies
        run: uv sync --locked --group docs

      - name: Build documentation (strict)
        run: uv run mkdocs build --strict
  {% endraw %}
  {% endif -%}

  {% raw -%}
  # ── Gate 4: Package Smoke Test (depends on static analysis) ─────────────
  package:
    name: Package Smoke Test
    needs: static-analysis
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Setup uv
        uses: astral-sh/setup-uv@v7
        with:
          enable-cache: true

      - name: Build distributions
        run: uv build

      - name: Verify wheel installs and imports
{% endraw -%}
        run: |
          {% raw -%}
          uv venv /tmp/smoke
          /tmp/smoke/bin/pip install dist/*.whl
          {% endraw -%}
          /tmp/smoke/bin/python -c "from {{ package_name }} import greet; print(greet('smoke'))"
