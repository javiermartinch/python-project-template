{% raw %}# =============================================================================
# Secure Publishing to PyPI via Trusted Publishers (OIDC)
# Zero secrets required — GitHub ↔ PyPI trust via ephemeral JWT tokens
# =============================================================================

name: Publish to PyPI

on:
  release:
    types: [published]

jobs:
  pypi-publish:
    name: Build & Publish to PyPI
    runs-on: ubuntu-latest

    # Link to GitHub Environment for deployment protection rules
    environment:
      name: pypi
{% endraw %}
      url: https://pypi.org/p/{{ project_name }}
{% raw %}
    # OIDC permissions — required for Trusted Publishing
    permissions:
      id-token: write
      contents: read

    steps:
      - uses: actions/checkout@v4

      - name: Setup uv
        uses: astral-sh/setup-uv@v7
        with:
          enable-cache: true

      - name: Build distributions (sdist + wheel)
        run: uv build

      - name: Publish to PyPI via OIDC
        uses: pypa/gh-action-pypi-publish@release/v1
        # No secrets needed — the action requests an OIDC token from GitHub
        # and PyPI mints an ephemeral 15-minute API token.
        # PEP 740 digital attestations are generated by default.
{% endraw %}
